{
  "name": "@dvgroup/api-bridge-node-red",
  "version": "0.0.0",
  "description": "Push data to the DVGroup API with Node-RED",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": ">=20.20"
  },
  "node-red": {
    "nodes": {
      "dvgroup-api-bridge": "dist/index.js",
      "dvgroup-api-credentials": "dist/credentials.js"
    },
    "version": ">=4.0.0"
  },
  "scripts": {
    "build": "rimraf 'dist' && tsc --outDir dist && cp src/*.html dist/ && cp -R src/icons dist/icons",
    "cover": "node --run jest -- --coverage",
    "format": "node --run prettier",
    "jest": "NODE_OPTIONS=--experimental-vm-modules NODE_ENV=test jest",
    "lint": "eslint 'src/**/*.ts'",
    "precz": "node --run build && node --run lint && node --run test",
    "prepublish": "npm run build",
    "prettier": "prettier --write 'src/**/*.ts'",
    "preversion": "node --run build && node --run lint && node --run test",
    "rebuild": "swc ./src -s -d dist -C jsc.target=es2022",
    "test": "node --run jest"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@swc/jest": "^0.2.39",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "nock": "^14.0.16",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "dependencies": {
    "@types/node-red": "^1.3.5",
    "debug": "^4.4.3",
    "yerror": "^11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiagRAMS-Technologies/api-bridge-node-red.git"
  },
  "keywords": [
    "node-red"
  ],
  "author": "The DV Group Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/DiagRAMS-Technologies/api-bridge-node-red/issues"
  },
  "prettier": {
    "semi": true,
    "printWidth": 80,
    "singleQuote": true,
    "trailingComma": "all",
    "proseWrap": "always"
  },
  "jest": {
    "coverageReporters": [
      "lcov",
      "html"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "roots": [
      "<rootDir>/src"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "@swc/jest",
        {}
      ]
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "(.+)\\.js": "$1"
    },
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "prettierPath": null
  },
  "homepage": "https://github.com/DiagRAMS-Technologies/api-bridge-node-red#readme"
}
